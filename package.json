{
  "name": "znam",
  "version": "0.1.10",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt -b firefox",
    "dev:chrome": "wxt",
    "build": "wxt build -b firefox",
    "build:chrome": "wxt build",
    "zip": "wxt zip -b firefox",
    "zip:chrome": "wxt zip",
    "lint:ext": "web-ext lint --source-dir .output/firefox-mv2",
    "sign": "wxt build -b firefox && web-ext sign --source-dir .output/firefox-mv2 --artifacts-dir web-ext-artifacts --channel unlisted",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@mozilla/readability": "^0.5.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "web-ext": "^10.4.0",
    "wxt": "^0.20.0"
  }
}
